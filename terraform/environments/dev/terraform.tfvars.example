aws_region   = "us-east-1"
project_name = "cloud-monitoring-platform-aws"
environment  = "dev"

vpc_cidr           = "10.10.0.0/16"
public_subnet_cidr = "10.10.1.0/24"
availability_zone  = "us-east-1a"

instance_type = "t3.micro"
key_name      = null

# SSM Session Manager is the default. If enabling SSH, set your public IP /32.
enable_ssh        = false
admin_access_cidr = "203.0.113.10/32"

root_volume_size = 12

# Seven days limits development log-storage cost.
log_retention_days = 7

# Optional. Leave null to avoid creating an email subscription.
alert_email = null
